root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,xml,csproj,props,targets,config}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{cs,cshtml,vb,vbhtml}]
indent_size = 4

[*.{aspx,ascx,master,svc}]
indent_size = 4

# Visual Studio sln files use tabs
[*.sln]
indent_style = tab
