@model TestWebsite.Models.ContentPageViewModel

<section class="hero hero--content">
    <div class="container hero__inner">
        <h1 class="hero__heading">@Model.Name</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Subheading))
        {
            <p class="hero__subheading">@Model.Subheading</p>
        }
    </div>
</section>
